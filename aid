# --- Helpers ---

log_history() {
    local cmd="$1"
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    mkdir -p ".aid_data" 2>/dev/null || true
    echo "[$timestamp] $cmd" >> ".aid_data/history.log" 2>/dev/null || true
}

source_config() {
    local file="$1"
    if [ -f "$file" ]; then
        # Read file line by line
        while IFS='=' read -r key value || [ -n "$key" ]; do
            # Skip comments and empty lines
            [[ "$key" =~ ^#.*$ ]] && continue
            [[ -z "$key" ]] && continue
            
            # Remove leading 'export '
            key=${key#export }
            
            # Trim whitespace
            key=$(echo "$key" | xargs)
            
            # Validate key
            if [[ ! "$key" =~ ^[A-Z0-9_]+$ ]]; then continue; fi

            # Clean value
            value=${value%\"}
            value=${value#\"}
            value=${value%\'}
            value=${value#\'}
            
            # Export
            export "$key=$value"
        done < "$file"
    fi
}

load_config() {
    GLOBAL_CONFIG_FILE="$HOME/.aid/config"
    # Load Global first
    source_config "$GLOBAL_CONFIG_FILE"
    
    # Load Local Secure (.aid_data/config) - PRIMARY
    if [ -f ".aid_data/config" ]; then
        source_config ".aid_data/config"
        CONFIG_FILE=".aid_data/config" # Update current active config
    # Backwards compatibility / Override
    elif [ -f ".env" ]; then
        source_config ".env"
        CONFIG_FILE=".env"
    fi
}

check_config() {
    config_found=0
    if [ -f ".aid_data/config" ]; then config_found=1; fi
    if [ -f ".env" ]; then config_found=1; fi
    if [ -f "$HOME/.aid/config" ]; then config_found=1; fi

    # Allow proceeding if no config file but CLI auth exists
    if [ "$config_found" -eq 0 ] && [ ! -f "$HOME/.gemini/oauth_creds.json" ]; then
        echo -e "${RED}❌ No configuration or session found.${NC}" 
        echo "   Run './aid init' to setup your project."
        exit 1
    fi
    
    load_config
    
    # Check for CLI auth if API key is missing
    if [ -z "$GEMINI_API_KEY" ] && [ ! -f "$HOME/.gemini/oauth_creds.json" ]; then
        echo -e "${RED}❌ No authentication found (API Key or 'gemini' CLI session).${NC}"
        echo "   Run './aid init' to setup your project."
        exit 1
    fi
    # Use config model or default
    if [ -n "$GEMINI_MODEL" ]; then GEMINI_MODEL="$GEMINI_MODEL"; fi
}

scan_codebase() {
    # Helper to gather context
    find . -maxdepth 2 -type f -not -path '*/.*' -not -path '*/node_modules*' -not -path '*/dist*' -not -name 'package-lock.json' -not -name '*.md' | head -n 20 | while read file; do
        if file "$file" | grep -q "text"; then
            echo "--- FILE: $file ---"
            cat "$file"
            echo ""
        fi
    done
}

call_gemini() {
    local prompt="$1"
    local output_file="$2"

    # Strategy: Use 'gemini' CLI if available
    if command -v gemini &> /dev/null && [ -f "$HOME/.gemini/oauth_creds.json" ]; then
        # Selection: use GEMINI_MODEL if set, otherwise default to a reliable one
        local model_to_use="gemini-1.5-pro"
        if [ -n "$GEMINI_MODEL" ]; then model_to_use="$GEMINI_MODEL"; fi
        
        # Log attempt
        # echo "   (Attempting AI via 'gemini' CLI using $model_to_use...)"
        
        if echo "$prompt" | gemini -m "$model_to_use" > "$output_file" 2>.gemini_err; then
            echo "✅ Output saved via 'gemini' CLI to $output_file"
            rm -f .gemini_err
            return
        else
            echo -e "${YELLOW}⚠️  'gemini' CLI failed ($model_to_use). Fallback in progress...${NC}"
            # cat .gemini_err # Show error if it's not a common ones
            rm -f .gemini_err
        fi
    fi

    # Fallback: Original curl method
    if [ -z "$GEMINI_API_KEY" ]; then
        echo -e "${RED}❌ No API Key for fallback mode.${NC}"
        exit 1
    fi
    
    # Escape prompt for JSON
    json_payload=$(python3 -c "import json, sys; print(json.dumps({'contents': [{'parts': [{'text': sys.argv[1]}]}]}))" "$prompt")

    response=$(curl -s -X POST \
        -H "Content-Type: application/json" \
        "https://generativelanguage.googleapis.com/v1beta/models/$GEMINI_MODEL:generateContent?key=$GEMINI_API_KEY" \
        -d "$json_payload")

    if echo "$response" | grep -q "\"error\":"; then
        echo "❌ API Error"
        # Check for 404 (Model Not Found)
        if echo "$response" | grep -q '"code": 404'; then
             echo "ℹ️  The model '$GEMINI_MODEL' was not found or is not supported."
             echo "🔍 Fetching available models for your key..."
             models_response=$(curl -s "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_API_KEY")
             if echo "$models_response" | grep -q "\"models\":"; then
                 echo "✅ Available Models:"
                 echo "$models_response" | python3 -c "import sys, json; print('\n'.join([m['name'].replace('models/', '') for m in json.load(sys.stdin)['models']]))"
                 echo ""
                 echo "👉 To use one of these, run: ./aid config GEMINI_MODEL <model_name>"
             else
                 echo "❌ Could not list models."
             fi
        else
            echo "$response"
        fi
        exit 1
    fi

    # Extract text
    report=$(echo "$response" | python3 -c "import sys, json; print(json.load(sys.stdin)['candidates'][0]['content']['parts'][0]['text'])")
    
    echo "$report" > "$output_file"
    echo "✅ Output saved to $output_file"
    echo ""
    # Optional: Print preview
    echo "$report" | head -n 10
    echo "... (full output in $output_file)"
}


