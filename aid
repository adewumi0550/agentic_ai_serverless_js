#!/bin/bash

# Agentic Deployment Integration CLI (Pure Shell Version)
# Uses curl and python3 (standard on macOS/Linux)
# No Node.js or npm required.

set -e

CONFIG_FILE=".env"
GEMINI_MODEL="gemini-1.5-pro"
AID_VERSION="1.0.4"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# --- Commands ---

cmd_version() {
    echo -e "${BOLD}🤖 Agentic Deployment Integration${NC} ${BLUE}v$AID_VERSION${NC}"
    # Optional: System info
    # echo -e "   ${GREEN}•${NC} System: $(uname -s)"
}

cmd_update() {
    echo -e "${CYAN}🔄 Checking for updates...${NC}"
    
    # 1. Fetch latest version number from GitHub
    latest_version=$(curl -s "https://raw.githubusercontent.com/adewumi0550/agentic_ai_serverless_js/main/aid" | grep '^AID_VERSION=' | cut -d'=' -f2 | tr -d '"')
    
    if [ -z "$latest_version" ]; then
        echo -e "${YELLOW}⚠️  Could not fetch latest version info.${NC}"
        # Fallback to force update if check fails? Or just ask user.
        read -p "Force update? [y/N] " force
        if [[ ! "$force" =~ ^[Yy]$ ]]; then exit 0; fi
    else
        if [ "$latest_version" == "$AID_VERSION" ]; then
            echo -e "${GREEN}✅ You are already on the latest version ($AID_VERSION).${NC}"
            exit 0
        fi
        echo -e "${BLUE}🚀 New version available: $latest_version${NC} (Current: $AID_VERSION)"
    fi

    echo "   Fetching latest installer from GitHub..."
    if curl -fsSL https://raw.githubusercontent.com/adewumi0550/agentic_ai_serverless_js/main/install.sh | bash; then
        echo ""
        echo -e "${GREEN}✅ Update complete!${NC}"
        echo "   New version:"
        "$0" version
    else
        echo -e "${RED}❌ Update failed. Please check your internet connection.${NC}"
        exit 1
    fi
}

# 1. Configuration
cmd_config() {
    GLOBAL_CONFIG_FILE="$HOME/.aid/config"
    target_config=""
    
    # Handle 'clean' command first
    if [ "$1" == "clean" ]; then
        echo "🧹 Cleaning local configuration..."
        if [ -f ".aid_data/config" ]; then rm ".aid_data/config"; echo "   Deleted .aid_data/config"; fi
        if [ -f ".env" ]; then rm ".env"; echo "   Deleted .env"; fi
        echo "✅ Local configuration cleaned. Now using global defaults (if any)."
        return
    fi

    # Handle --global flag
    if [[ "$*" == *"--global"* ]]; then
        is_global=1
        # Remove --global from args
        set -- "${@//--global/}"
        target_config="$GLOBAL_CONFIG_FILE"
        mkdir -p "$HOME/.aid_data"
    else
        is_global=0
        load_config # Sets CONFIG_FILE to local or global
        target_config="$CONFIG_FILE"
        # If no local config exists and we are writing, default to creating local .aid_data/config
        if [ -z "$target_config" ] || [ "$target_config" == "$GLOBAL_CONFIG_FILE" ]; then
             if [ -n "$2" ]; then # We are writing
                 target_config=".aid_data/config"
                 mkdir -p ".aid_data"
             fi
        fi
    fi
 
    key="$1"
    val="$2"

    if [ -z "$key" ]; then
        echo "🔧 Configuration ($(if [ "$is_global" -eq 1 ]; then echo "Global"; else echo "Effective/Local"; fi))"
        if [ -f "$target_config" ]; then
            cat "$target_config"
        else
            echo "No configuration file found at $target_config."
        fi
        echo ""
        echo "Usage: ./aid config [key] [value] [--global]"
        echo "       ./aid config [key] --delete"
        echo "       ./aid config clean"
        return
    fi
     
    # ... rest of logic (delete/set) using $target_config instead of $CONFIG_FILE
    if [[ "$val" == "--delete" || "$val" == "-d" ]]; then
        if [ -f "$target_config" ]; then
            sed -i '' "/^$key=/d" "$target_config"
            echo "🗑️  Deleted $key from $target_config"
        else
            echo "❌ No config file found at $target_config"
        fi
        return
    fi

    if [ -z "$val" ]; then
        # Get value
        val=$(grep "^$key=" "$target_config" 2>/dev/null | cut -d'=' -f2)
        echo "$key=$val"
    else
        # Set value
        if [ -f "$target_config" ]; then
             sed -i '' "/^$key=/d" "$target_config"
        fi
        echo "$key=\"$val\"" >> "$target_config"
        echo "✅ Set $key=\"$val\" in $target_config"
    fi
}

# Helper to ensure .gitignore has essential entries
ensure_gitignore() {
    TOUCHED=0
    if [ ! -f ".gitignore" ]; then
        touch .gitignore
        echo -e "${GREEN}✅ Created .gitignore${NC}"
        TOUCHED=1
    fi

    # List of patterns to enforce
    IGNORES=(
        "node_modules/"
        "dist/"
        "build/"
        ".env"
        ".DS_Store"
        ".aid_data/"
        "aid_out/"
        "yarn-cache/"
        "coverage/"
        "*.log"
    )

    for pattern in "${IGNORES[@]}"; do
        if ! grep -qF "$pattern" ".gitignore"; then
            echo "$pattern" >> .gitignore
            echo -e "   ${YELLOW}+ Added $pattern to .gitignore${NC}"
            TOUCHED=1
        fi
    done

    if [ "$TOUCHED" -eq 1 ]; then
        echo -e "${GREEN}🔒 Secured project workspace.${NC}"
    fi
}

cmd_init() {
    echo "👋 Welcome to Agentic Deployment Integration"
    
    # 1. Setup Gemini Key
    # 1. Setup Gemini Key
    target_config=".aid_data/config"
    mkdir -p ".aid_data"
    
    # Secure: Add to .gitignore if not present
    ensure_gitignore

    # Check if global config exists and load it
    if [ -f "$GLOBAL_CONFIG_FILE" ]; then
        source_config "$GLOBAL_CONFIG_FILE" # Helper to load
    fi
    # Check for local .aid/config
    if [ -f "$target_config" ]; then
        source_config "$target_config"
    fi

    # Detect existing gemini CLI auth
    has_gemini_cli_auth=0
    if [ -f "$HOME/.gemini/oauth_creds.json" ]; then
        has_gemini_cli_auth=1
    fi

    if [ -z "$GEMINI_API_KEY" ] && [ "$has_gemini_cli_auth" -eq 1 ]; then
        echo -e "${GREEN}✅ Authenticated via 'gemini' CLI.${NC}"
    elif [ -z "$GEMINI_API_KEY" ]; then
        echo -e "${YELLOW}⚠️  No active session found.${NC}"
        echo "   Please login to the 'gemini' CLI or provide an API Key."
        echo ""
        read -p "Do you want to setup an API Key now? [y/N]: " setup_key
        if [[ "$setup_key" =~ ^[Yy]$ ]]; then
            while true; do
                read -sp "Enter your Gemini API Key: " api_key
                echo ""
                if [ -z "$api_key" ]; then echo "❌ API Key cannot be empty."; continue; fi
                echo "Testing API Key..."
                response=$(curl -s -o /dev/null -w "%{http_code}" "https://generativelanguage.googleapis.com/v1beta/models?key=$api_key")
                if [ "$response" -eq 200 ]; then echo "✅ API Key is valid!"; break;
                else echo "❌ Invalid API Key (HTTP $response). Please try again."; fi
            done
            echo "Where do you want to save this key?"
            echo "  (l) Local Secure (.aid/config) - Recommended"
            echo "  (g) Global (~/.aid/config) - Developer defaults"
            read -p "Select [l/g]: " save_loc
            if [[ "$save_loc" == "g" ]]; then target_config="$GLOBAL_CONFIG_FILE"; else target_config=".aid_data/config"; fi
            echo "GEMINI_API_KEY=\"$api_key\"" >> "$target_config"
            echo "GEMINI_MODEL=\"$GEMINI_MODEL\"" >> "$target_config"
            export GEMINI_API_KEY="$api_key"
        fi
    else
        echo -e "${GREEN}✅ Gemini API Key found.${NC}"
    fi

    # 2. Detect Stack (Interactive or Auto)
    echo ""
    echo "🔍 Configuration Setup"
    echo "------------------------"
    
    # Language
    if [ -f "package.json" ]; then default_lang="Node.js"; 
    elif [ -f "requirements.txt" ]; then default_lang="Python";
    elif [ -f "go.mod" ]; then default_lang="Go";
    elif [ -f "pubspec.yaml" ]; then default_lang="Flutter/Dart";
    elif [ -f "composer.json" ]; then default_lang="PHP";
    elif [ -f "index.html" ]; then default_lang="HTML/Web";
    else default_lang="Unknown"; fi
    
    read -p "Project Language [$default_lang]: " input_lang
    lang="${input_lang:-$default_lang}"
    echo "PROJECT_LANGUAGE=\"$lang\"" >> "$target_config"
    
    # Project Type
    echo ""
    echo "Select Project Type:"
    echo "  1) Web App (Frontend/Fullstack)"
    echo "  2) API / Backend Service"
    echo "  3) Mobile App"
    echo "  4) CLI Tool"
    echo "  5) Other"
    read -p "Enter Choice [1]: " type_choice
    
    case "${type_choice:-1}" in
        1) proj_type="Web App" ;;
        2) proj_type="API/Backend" ;;
        3) proj_type="Mobile App" ;;
        4) proj_type="CLI Tool" ;;
        *) proj_type="Other" ;;
    esac
    echo "PROJECT_TYPE=\"$proj_type\"" >> "$target_config"
    
    echo ""
    echo "✅ Setup Complete!"
    echo "   Configuration saved to $target_config"
    echo "   Run './aid deploy' when you are ready to configure deployment."
}

# 2. Agentic Workflows

cmd_ask() {
    check_config
    if [ -z "$1" ]; then
        echo "❌ Usage: ./aid ask \"your question about the codebase\""
        exit 1
    fi
    echo "🤔 Thinking..."
    context=$(scan_codebase)
    prompt="You are an expert developer. Answer this question based on the codebase context provided.\n\nContext:\n$context\n\nQuestion: $1"
    call_gemini "$prompt" "aid_answer.md"
}

cmd_review() {
    check_config
    echo "🧐 Reviewing codebase..."
    context=$(scan_codebase)
    prompt="You are a senior staff engineer. Perform a thorough code review of this codebase. Focus on security, performance, and maintainability. Structure your response with a summary followed by file-by-file comments."
    call_gemini "$prompt" "code_review.md" 
}

cmd_refactor() {
    check_config
    if [ -z "$1" ]; then
        echo "❌ Usage: ./aid refactor <file_path> \"refactoring instructions\""
        exit 1
    fi
    file="$1"
    instruction="$2"
    
    if [ ! -f "$file" ]; then
        echo "❌ File $file not found."
        exit 1
    fi
    
    content=$(cat "$file")
    echo "🔧 Refactoring $file..."
    prompt="You are an expert refactorer. Refactor the code in '$file' according to these instructions: '$instruction'. \n\nOriginal Code:\n$content\n\nReturn ONLY the full refactored code block."
    call_gemini "$prompt" "${file}.refactored"
}

cmd_analyze() {
    check_config
    echo "🔍 Analyzing project structure and infrastructure..."
    
    # 1. Detect Infrastructure
    infra_context=""
    if [ -f "Dockerfile" ]; then infra_context="$infra_context\n- Dockerfile detected."; fi
    if [ -f "docker-compose.yml" ]; then infra_context="$infra_context\n- Docker Compose detected."; fi
    if [ -f "go.mod" ]; then infra_context="$infra_context\n- Go detected."; fi
    if [ -f "composer.json" ]; then infra_context="$infra_context\n- PHP/Composer detected."; fi
    if [ -f "index.html" ]; then infra_context="$infra_context\n- HTML detected."; fi
    
    # 2. Gather File Context
    code_context=$(scan_codebase)
    
    # Save context for user reference
    mkdir -p "aid_out"
    echo "$code_context" > "aid_out/project_context.txt"
    echo "📄 Project context saved to aid_out/project_context.txt"
    
    # 3. User Rules
    user_rules=""
    if [ -f ".aid_data/rules.md" ]; then
        user_rules="\n\nUSER CONFIG / RULES:\n$(cat .aid_data/rules.md)\n"
    fi
    
    # Load previously saved project info if available
    proj_lang="${PROJECT_LANGUAGE:-Auto-Detect}"
    proj_type="${PROJECT_TYPE:-Auto-Detect}"
    
    # 4. Build Prompt
    prompt="You are a Principal DevOps Engineer. Provide a brief, strategic summary of this codebase.\n\n"
    prompt="${prompt}Project Config: Language='$proj_lang', Type='$proj_type'\n"
    prompt="${prompt}Infrastructure Context:${infra_context}\n\n"
    prompt="${prompt}Codebase Context:\n${code_context}\n${user_rules}\n"
    prompt="${prompt}Output EXACTLY these 5 lines, with at most ONE sentence per line:\n"
    prompt="${prompt}Project name: [Name]\n"
    prompt="${prompt}Programming script: [Language/Framework]\n"
    prompt="${prompt}DB or related: [Database details]\n"
    prompt="${prompt}Month estimate cost: [Projected cost in USD]\n"
    prompt="${prompt}service recommened: [Specific GCP/Platform service]\n\n"
    prompt="${prompt}Do NOT provide extra text, tables, or implementation details."

    echo "🧠 Generating Agentic Report..."
    call_gemini "$prompt" "aid_out/deployment_plan.md"
    cp "aid_out/deployment_plan.md" "AGENTIC_REPORT.md" # Keep legacy link for now
    log_history "analyze"
}

cmd_docs() {
    check_config
    echo "📚 Generating documentation..."
    context=$(scan_codebase)
    prompt="Generate comprehensive documentation for this project. Include an Overview, Setup Guide, API Reference (if applicable), and Architecture description. Output in Markdown."
    call_gemini "$prompt" "PROJECT_DOCS.md"
    log_history "docs"
}

cmd_report() {
    if [ ! -f "AGENTIC_REPORT.md" ]; then
        echo "⚠️  No report found. Generating one now..."
        cmd_analyze
    fi
    
    echo "📄 Displaying Agentic Report..."
    echo "--------------------------------------------------"
    if command -v mdcat >/dev/null 2>&1; then
        mdcat "AGENTIC_REPORT.md"
    else
        cat "AGENTIC_REPORT.md"
    fi
    echo "--------------------------------------------------"
}

cmd_generate() {
    check_config
    if [ -z "$1" ]; then
        echo "❌ Usage: ./aid gen \"Describe the code you want to generate\""
        exit 1
    fi
    echo "👨‍💻 Generating code..."
    prompt="You are an expert software engineer. Generate high-quality, production-ready code for the following request. Return ONLY the code/markdown.\n\nRequest: $1"
    call_gemini "$prompt" "generated_code.md"
    log_history "gen"
}

cmd_recommend() {
    check_config
    echo "💡 Generating strategic recommendations..."
    context=$(scan_codebase)
    prompt="You are a Principal Architect. Provide 5-10 high-impact recommendations for this codebase. \n\nContext: $context\n\nOutput ONLY a bulleted list where each point is EXACTLY one sentence long."
    call_gemini "$prompt" "RECOMMENDATION.md"
    log_history "recommend"
}

cmd_plan() {
    check_config
    echo -e "${BLUE}📋 Creating Master Application Plan...${NC}"
    
    echo -e "\n1. ${CYAN}Generating App Report (AGENTIC_REPORT.md)...${NC}"
    cmd_analyze
    
    echo -e "2. ${CYAN}Generating App Recommendations (RECOMMENDATION.md)...${NC}"
    cmd_recommend
    
    echo -e "3. ${CYAN}Generating Deployment Strategy (DEPLOYMENT_PLAN.md)...${NC}"
    DEPLOY_PLAN_ONLY=1 cmd_deploy
    
    echo ""
    echo -e "${GREEN}✅ Plan Complete! Generated 3 documents:${NC}"
    echo "   - AGENTIC_REPORT.md (Architecture)"
    echo "   - RECOMMENDATION.md (Optimizations)"
    echo "   - DEPLOYMENT_PLAN.md (Ops Strategy)"
}

cmd_history() {
    if [ -f ".aid_data/history.log" ]; then
        echo "📜 Developer History:"
        cat ".aid_data/history.log"
    else
        echo "No history yet."
    fi
}

cmd_gemini() {
    if ! command -v gemini &> /dev/null; then
        echo -e "${RED}❌ 'gemini' CLI tool not found.${NC}"
        echo "   Please install it or ensure it is in your PATH."
        exit 1
    fi
    echo -e "${CYAN}🤖 Proxying to 'gemini' CLI...${NC}"
    gemini "$@"
}

# 3. Core & Serverless

cmd_start() {
    echo "🚀 Starting local server..."
    # Placeholder: Detect project type and run appropriate start command
    if [ -f "package.json" ]; then npm start; 
    elif [ -f "main.py" ]; then python3 main.py;
    elif [ -f "composer.json" ]; then php -S localhost:8000;
    elif [ -f "index.html" ]; then python3 -m http.server;
    else echo "UNKNOWN PROJECT TYPE. Please add a start script."; fi
}

cmd_deploy() {
    check_config
    
    echo "🕵️  Agentic Deployment Initiated..."
    echo "---------------------------------"
    
    # 1. Check/Set Deployment Platform
    if [ -z "$DEPLOYMENT_PLATFORM" ]; then
        echo "🚀 Choose your deployment target:"
        echo "1. AWS"
        echo "2. GCP (Google Cloud)"
        echo "3. Vercel"
        echo "4. Render"
        echo "5. DigitalOcean"
        echo "6. Other (Generic)"
        read -p "Select (1-6): " platform_choice

        case "$platform_choice" in
            1)
                platform="AWS"
                read -p "AWS Access Key ID: " aws_key
                read -sp "AWS Secret Access Key: " aws_secret
                echo ""
                if [ -f "$CONFIG_FILE" ]; then
                    echo "AWS_ACCESS_KEY_ID=\"$aws_key\"" >> "$CONFIG_FILE"
                    echo "AWS_SECRET_ACCESS_KEY=\"$aws_secret\"" >> "$CONFIG_FILE"
                fi
                ;;
            2)
                platform="GCP"
                # Use cached PROJECT_ID if available
                default_project="${GCP_PROJECT_ID:-campuscook-8e47c}"
                read -p "GCP Project ID [$default_project]: " gcp_project
                gcp_project="${gcp_project:-$default_project}"
                
                default_service="${GCP_SERVICE_NAME:-lexiguide}"
                read -p "Cloud Run Service Name [$default_service]: " gcp_service
                gcp_service="${gcp_service:-$default_service}"
                
                default_region="${GCP_REGION:-us-central1}"
                read -p "GCP Region [$default_region]: " gcp_region
                gcp_region="${gcp_region:-$default_region}"

                if [ -f "$CONFIG_FILE" ]; then
                     # Clean old values
                     sed -i '' "/^GCP_PROJECT_ID=/d" "$CONFIG_FILE"
                     sed -i '' "/^GCP_SERVICE_NAME=/d" "$CONFIG_FILE"
                     sed -i '' "/^GCP_REGION=/d" "$CONFIG_FILE"
                     
                     echo "GCP_PROJECT_ID=\"$gcp_project\"" >> "$CONFIG_FILE"
                     echo "GCP_SERVICE_NAME=\"$gcp_service\"" >> "$CONFIG_FILE"
                     echo "GCP_REGION=\"$gcp_region\"" >> "$CONFIG_FILE"
                fi
                export GCP_PROJECT_ID="$gcp_project"
                export GCP_SERVICE_NAME="$gcp_service"
                export GCP_REGION="$gcp_region"
                echo "ℹ️  Note: Ensure you have 'gcloud' installed and authenticated."
                ;;
            3)
                platform="Vercel"
                read -sp "Vercel Token: " vercel_token
                echo ""
                if [ -f "$CONFIG_FILE" ]; then
                    echo "VERCEL_TOKEN=\"$vercel_token\"" >> "$CONFIG_FILE"
                fi
                ;;
            4)
                platform="Render"
                read -sp "Render API Key: " render_key
                echo ""
                if [ -f "$CONFIG_FILE" ]; then
                    echo "RENDER_API_KEY=\"$render_key\"" >> "$CONFIG_FILE"
                fi
                ;;
            5)
                platform="DigitalOcean"
                read -sp "DO Personal Access Token: " do_token
                echo ""
                if [ -f "$CONFIG_FILE" ]; then
                    echo "DIGITALOCEAN_TOKEN=\"$do_token\"" >> "$CONFIG_FILE"
                fi
                ;;
            *)
                platform="Generic"
                ;;
        esac
        
        echo "DEPLOYMENT_PLATFORM=\"$platform\"" >> "$CONFIG_FILE"
        export DEPLOYMENT_PLATFORM="$platform"
        echo "✅ Platform configured: $platform"
    else
        echo "✅ Platform already configured: $DEPLOYMENT_PLATFORM"
        platform="$DEPLOYMENT_PLATFORM"
    fi

    # Check if we only want the plan
    if [ -n "$DEPLOY_PLAN_ONLY" ]; then
        echo -e "${CYAN}🧠 Generating deployment plan for $platform...${NC}"
        stack="${PROJECT_LANGUAGE:-Auto-Detect}"
        ptype="${PROJECT_TYPE:-Auto-Detect}"
        context=$(scan_codebase)
        prompt="You are a Principal DevOps Engineer. The user wants to deploy to **$platform**. \n\nContext: $context\n\nGenerate **DEPLOYMENT_PLAN.md** with: \n1. Architecture (1 sentence)\n2. Config (Essential Dockerfile/YAML ONLY)\n3. Deployment Steps (Shell commands ONLY).\nKeep it extremely concise."
        call_gemini "$prompt" "aid_out/DEPLOYMENT_PLAN.md"
        cp "aid_out/DEPLOYMENT_PLAN.md" "DEPLOYMENT_PLAN.md"
        echo -e "${GREEN}✅ Plan Generated: DEPLOYMENT_PLAN.md${NC}"
        return
    fi
    echo -e "${CYAN}🧠 Generating deployment plan for $platform...${NC}"
    
    stack="${PROJECT_LANGUAGE:-Auto-Detect}"
    ptype="${PROJECT_TYPE:-Auto-Detect}"
    
    context=$(scan_codebase)
    prompt="You are a Principal DevOps Engineer. The user has a **$stack** project (Type: **$ptype**) and wants to deploy to **$platform**.\n\n"
    prompt="${prompt}**Project Context**:\n$context\n\n"
    prompt="${prompt}Generate a detailed **DEPLOYMENT_PLAN.md** structured as follows:\n"
    prompt="${prompt}### 1. 🏗️ Architecture & Prerequisites\n"
    prompt="${prompt}- Necessary tools (CLI, accounts).\n"
    prompt="${prompt}- Expected costs/limits for $platform.\n"
    prompt="${prompt}### 2. ⚙️ Configuration\n"
    prompt="${prompt}- Create/Update these files (Dockerfile, serverless.yml, etc.). provide FULL CODE content.\n"
    prompt="${prompt}### 3. 🚀 Deployment Steps\n"
    prompt="${prompt}- Step-by-step shell commands to deploy.\n"
    prompt="${prompt}- How to inject environment variables (referencing local .env keys).\n"
    prompt="${prompt}### 4. 🔍 Verification\n"
    prompt="${prompt}- How to check logs and health.\n\n"
    prompt="${prompt}Output ONLY valid Markdown. Use specific icons and headers to make it look professional."
    
    call_gemini "$prompt" "aid_out/DEPLOYMENT_PLAN.md"
    cp "aid_out/DEPLOYMENT_PLAN.md" "DEPLOYMENT_PLAN.md"

    echo -e "${GREEN}✅ Plan Generated: DEPLOYMENT_PLAN.md${NC}"
    read -p "View plan now? [Y/n] " view_plan
    if [[ ! "$view_plan" =~ ^[Nn]$ ]]; then
        if command -v mdcat >/dev/null 2>&1; then mdcat "DEPLOYMENT_PLAN.md"; else cat "DEPLOYMENT_PLAN.md"; fi
    fi

    echo ""
    read -p "Proceed with automated deployment steps? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${YELLOW}❌ Deployment execution cancelled. Follow the manual plan above.${NC}"
        exit 0
    fi
    
    echo -e "${BLUE}🚀 Executing deployment basics...${NC}"
    case "$platform" in
        AWS) echo "aws s3 sync . s3://bucket --dryrun" ;;
        GCP)
            project="${GCP_PROJECT_ID:-campuscook-8e47c}"
            service="${GCP_SERVICE_NAME:-lexiguide}"
            region="${GCP_REGION:-us-central1}"
            
            echo -e "${CYAN}📦 Building and pushing container image for $service to $project...${NC}"
            gcloud builds submit --tag gcr.io/"$project"/"$service" --project "$project"
            
            echo -e "${CYAN}🌍 Deploying to Cloud Run in $region...${NC}"
            gcloud run deploy "$service" \
              --image gcr.io/"$project"/"$service" \
              --platform managed \
              --region "$region" \
              --allow-unauthenticated \
              --project "$project"
            ;;
        Vercel) echo "vercel --prod" ;;
        *) echo "Generic deployment script" ;;
    esac
    log_history "deploy"
}

cmd_push() {
    check_config
    
    # Ensure ignores before adding
    ensure_gitignore
    
    # Safety: Remove cached ignored files if they were accidentally added
    IGNORED_ITEMS=("node_modules" "dist" "build" ".env" ".DS_Store" ".aid_data" "aid_out" "yarn-cache" "coverage")
    for item in "${IGNORED_ITEMS[@]}"; do
        if git ls-files --error-unmatch "$item" >/dev/null 2>&1; then
             echo -e "${YELLOW}🧹 Removing $item from git index...${NC}"
             git rm -r --cached "$item" >/dev/null 2>&1
        fi
    done

    if [ ! -d ".git" ]; then
        echo "❌ Not a git repository."
        exit 1
    fi

    echo "🕵️  Scanning for changes..."
    # Auto-stage all changes
    git add .
    
    # Check if there are changes to commit
    if git diff --cached --quiet; then
        echo "✅ No changes to commit."
        # Check if there are commits to push
        unpushed=$(git log origin/main..HEAD 2>/dev/null)
        if [ -n "$unpushed" ]; then
             echo "🚀 Pushing existing commits..."
             git push
             exit 0
        fi
        exit 0
    fi

    echo "🧠 Generating semantic commit message..."
    
    # Get diff for context (limit lines to avoid huge payloads)
    diff_content=$(git diff --cached | head -n 50)
    
    prompt="You are a senior developer. Generate a CONCISE, Conventional Commit message (e.g., 'feat: ...', 'fix: ...', 'docs: ...') for this diff. Return ONLY the message string. Do not use quotes.\n\nDiff Context:\n$diff_content"
    
    # Generate message to a temp file
    call_gemini "$prompt" ".commit_msg.tmp" > /dev/null 2>&1
    
    if [ ! -f ".commit_msg.tmp" ]; then
        echo "❌ Failed to generate commit message."
        exit 1
    fi
    
    commit_msg=$(cat ".commit_msg.tmp")
    rm ".commit_msg.tmp"
    
    echo ""
    echo "--------------------------------------------------"
    echo "🤖 Proposed Commit Message:"
    echo "   $commit_msg"
    echo "--------------------------------------------------"
    echo ""
    
    echo "Do you want to proceed?"
    echo "  (y) Yes, commit and push"
    echo "  (n) No, abort"
    echo "  (e) Edit message manually"
    read -p "Select [y/n/e]: " choice
    
    case "$choice" in
        y|Y)
            echo "🚀 Committing..."
            git commit -m "$commit_msg"
            echo "☁️  Pushing to remote..."
            git push
            echo "✅ Done!"
            ;;
        e|E)
            read -p "Enter your commit message: " custom_msg
            git commit -m "$custom_msg"
            echo "☁️  Pushing to remote..."
            git push
            echo "✅ Done!"
            ;;
        *)
            echo "❌ Aborted. Changes are staged."
            exit 0
            ;;
    esac
    log_history "push"
}

